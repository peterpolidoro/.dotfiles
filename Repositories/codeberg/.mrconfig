[spritely-papers]
checkout =
	git clone 'ssh://git@codeberg.org/peterpolidoro/spritely-papers.git' 'spritely-papers'
	cd spritely-papers
	git remote add source ssh://git@codeberg.org/spritely/papers.git

[emacs-config-peter]
checkout =
	git clone 'ssh://git@codeberg.org/peterpolidoro/emacs-config-peter.git' 'emacs-config-peter'

[addresses]
checkout =
	git clone 'ssh://git@codeberg.org/peterpolidoro/addresses.git' 'addresses'

[guix-artwork]
checkout =
	git clone 'ssh://git@codeberg.org/peterpolidoro/guix-artwork.git' 'guix-artwork'
	cd guix-artwork
	git remote add source ssh://git@codeberg.org/guix/artwork.git

