[emacs-config]
checkout =
	git clone 'ssh://git@codeberg.org/orb-weaver/emacs-config.git' 'emacs-config'
	cd emacs-config
	git remote add codeberg ssh://git@codeberg.org/orb-weaver/emacs-config.git

